

<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grāmatu Pasaule</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f2f2f2;
    color:#222;
}

.container{
    width:1100px;
    margin:auto;
    background:white;
}

/* HEADER */

header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 40px;
    border-bottom:1px solid #ccc;
}

.logo{
    font-size:28px;
    font-weight:bold;
    color:#5a3e2b;
}

nav a{
    margin-left:25px;
    text-decoration:none;
    color:black;
    font-weight:bold;
}

nav a:hover{
    color:#8b5e3c;
}

/* HERO */

.hero{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:60px 40px;
    background:#faf7f2;
}

.hero-text{
    width:50%;
}

.hero-text h1{
    font-size:42px;
    margin-bottom:20px;
}

.hero-text p{
    margin-bottom:25px;
    line-height:1.6;
}

.buttons button{
    padding:12px 25px;
    border:none;
    cursor:pointer;
    margin-right:15px;
    border-radius:5px;
    font-weight:bold;
    transition:0.3s;
}

.buttons button:hover{
    transform:scale(1.05);
}

.btn1{
    background:#d6b98c;
}

.btn2{
    background:#b8c7e0;
}

.hero-image img{
    width:400px;
    height:250px;
    object-fit:cover;
    border-radius:10px;
}

/* BOOKS */

.books{
    padding:50px 40px;
    display:flex;
    gap:20px;
}

.card{
    flex:1;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.card-image img{
    width:100%;
    height:200px;
    object-fit:cover;
    border-radius:10px;
    margin-bottom:15px;
}

.card h3{
    margin-bottom:10px;
}

.card a{
    color:#5a3e2b;
    font-weight:bold;
}

/* AD */

.ad{
    background:#dce8d6;
    text-align:center;
    padding:70px 20px;
}

.ad h2{
    font-size:40px;
    margin-bottom:30px;
}

.ad-buttons button{
    padding:14px 35px;
    border:none;
    margin:10px;
    cursor:pointer;
    font-size:16px;
    border-radius:5px;
    transition:0.3s;
}

.ad-buttons button:hover{
    opacity:0.8;
}

.buy{
    background:#e6d8aa;
}

.try{
    background:#e8b9b9;
}

/* SLIDER */

.slider{
    position:relative;
    margin:50px 40px;
}

.slider img{
    width:100%;
    height:450px;
    object-fit:cover;
    border-radius:10px;
}

.arrow{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    font-size:50px;
    color:white;
    cursor:pointer;
    background:rgba(0,0,0,0.4);
    padding:10px;
}

.left{
    left:10px;
}

.right{
    right:10px;
}

/* INFO */

.info{
    padding:50px 40px;
}

.info h2{
    font-size:38px;
    margin-bottom:20px;
}

.info p{
    margin-bottom:20px;
    line-height:1.6;
}

.info ul{
    margin-left:20px;
    margin-bottom:30px;
}

table{
    width:100%;
    border-collapse:collapse;
    text-align:center;
}

td{
    border:1px solid #ccc;
    padding:20px;
}

/* FOOTER */

footer{
    background:#efe3c4;
    padding:40px;
}

.footer-content{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.footer-links a{
    display:block;
    color:black;
    margin-bottom:10px;
}

.author{
    text-align:center;
    padding-top:20px;
    margin-top:20px;
    border-top:1px solid #ccc;
}

#datums{
    text-align:center;
    margin-top:20px;
    font-weight:bold;
}

</style>
</head>

<body>

<div class="container">

<!-- HEADER -->

<header>

