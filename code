<!-- JAVASCRIPT -->

<script>

function sveiciens(){
    alert("Laipni lūdzam Grāmatu Pasaulē!");
}

function mainitFondu(){

    if(document.body.style.background == "rgb(223, 230, 233)"){
        document.body.style.background = "#f2f2f2";
    }

    else{
        document.body.style.background = "#dfe6e9";
    }
}

/* SLIDER */

let bildes = [

"https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=1200&auto=format&fit=crop",

"https://images.unsplash.com/photo-1521587760476-6c12a4b040da?q=80&w=1200&auto=format&fit=crop",

"https://images.unsplash.com/photo-1495446815901-a7297e633e8d?q=80&w=1200&auto=format&fit=crop"

];

let indekss = 0;

function nakosa(){

    indekss++;

    if(indekss >= bildes.length){
        indekss = 0;
    }

    document.getElementById("slideImage").src = bildes[indekss];
}

function iepriekseja(){

    indekss--;

    if(indekss < 0){
        indekss = bildes.length - 1;
    }

    document.getElementById("slideImage").src = bildes[indekss];
}

/* DATUMS */

let sodiena = new Date();

document.getElementById("datums").innerHTML =
"Šodienas datums: " + sodiena.toLocaleDateString();

/* AUTOMĀTISKS SLAIDERIS */

setInterval(nakosa, 4000);

</script>

